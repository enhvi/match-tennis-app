rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function convOtherUid(parts) {
      return parts[0] == request.auth.uid ? parts[1] : parts[0];
    }

    // —— Conversations (unchanged) ——
    match /conversations/{conversationId} {
      allow read: if request.auth != null &&
        request.auth.uid in resource.data.participants;

      allow create: if request.auth != null &&
        request.resource.data.participants is list &&
        request.resource.data.participants.size() == 2 &&
        request.auth.uid in request.resource.data.participants &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)/friends/$(convOtherUid(request.resource.data.participants)));

      allow update: if request.auth != null &&
        request.auth.uid in resource.data.participants;

      allow delete: if false;

      match /messages/{messageId} {
        allow read: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;

        allow create: if request.auth != null &&
          request.resource.data.keys().hasAll(['senderId', 'text', 'createdAt']) &&
          request.resource.data.senderId == request.auth.uid &&
          request.resource.data.text is string &&
          request.resource.data.text.size() > 0 &&
          request.resource.data.text.size() <= 500 &&
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;

        allow update, delete: if false;
      }
    }

    // —— User profiles ——
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update, delete: if request.auth != null && request.auth.uid == userId;

      match /friends/{friendId} {
        allow read: if request.auth != null &&
          (request.auth.uid == userId || request.auth.uid == friendId);
        allow create, update, delete: if request.auth != null &&
          (request.auth.uid == userId || request.auth.uid == friendId);
      }

      match /friendRequests/{requestId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null &&
          request.resource.data.fromUid == request.auth.uid &&
          request.resource.data.keys().hasAll(['fromUid', 'createdAt']);
        allow delete: if request.auth != null &&
          (request.auth.uid == userId || resource.data.fromUid == request.auth.uid);
        allow update: if false;
      }

      match /notifications/{notificationId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null &&
          request.resource.data.keys().hasAll(['type', 'read']) &&
          request.resource.data.type is string &&
          request.resource.data.type.size() > 0 &&
          request.resource.data.type.size() < 80;
        allow update: if request.auth != null && request.auth.uid == userId;
        allow delete: if request.auth != null && request.auth.uid == userId;
      }
    }

    // —— Match requests ——
    function matchParticipant() {
      return request.auth != null && (
        resource.data.creatorId == request.auth.uid ||
        request.auth.uid in resource.data.friendIds
      );
    }

    function matchParticipantNew() {
      return request.auth != null && (
        request.resource.data.creatorId == request.auth.uid ||
        request.auth.uid in request.resource.data.friendIds
      );
    }

    function matchImmutableCoreUnchanged() {
      let r = resource.data;
      let n = request.resource.data;
      return r.creatorId == n.creatorId &&
        r.friendIds == n.friendIds &&
        r.date == n.date &&
        r.startTime == n.startTime &&
        r.endTime == n.endTime &&
        r.sport == n.sport &&
        r.playersNeeded == n.playersNeeded &&
        r.inviteAll == n.inviteAll &&
        r.durationMinutes == n.durationMinutes &&
        r.timeMode == n.timeMode &&
        r.location == n.location &&
        r.comment == n.comment &&
        r.creatorDisplayName == n.creatorDisplayName &&
        r.creatorUsername == n.creatorUsername &&
        r.creatorPhotoURL == n.creatorPhotoURL;
    }

    function friendAllowedTopStatus() {
      let s = request.resource.data.status;
      return s == 'pending' || s == 'confirmed';
    }

    match /matchRequests/{requestId} {
      allow read: if request.auth != null && (
        resource.data.creatorId == request.auth.uid ||
        request.auth.uid in resource.data.friendIds
      );

      allow create: if request.auth != null &&
        request.resource.data.creatorId == request.auth.uid &&
        request.resource.data.status == 'pending' &&
        request.resource.data.keys().hasAll(['creatorId', 'friendIds', 'date', 'sport', 'status', 'createdAt']) &&
        request.resource.data.friendIds is list;

      allow delete: if request.auth != null &&
        resource.data.creatorId == request.auth.uid;

      allow update: if request.auth != null && resource.data.creatorId == request.auth.uid;

      allow update: if request.auth != null &&
        request.auth.uid in resource.data.friendIds &&
        matchImmutableCoreUnchanged() &&
        friendAllowedTopStatus();
    }
  }
}
